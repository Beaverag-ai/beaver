# Beaver RAG Platform - Environment Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8741
API_WORKERS=1
DEBUG=false

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://beaver:beaver@localhost:5491/beaver

# =============================================================================
# Vector Store (pgvector — uses same PostgreSQL database)
# =============================================================================
VECTOR_COLLECTION=beaver_knowledge

# =============================================================================
# LLM Backend (SGLang - OpenAI-compatible)
# =============================================================================
SGLANG_URL=http://localhost:30091
DEFAULT_MODEL=beaver-default

# =============================================================================
# Embeddings (Ollama)
# =============================================================================
OLLAMA_URL=http://localhost:11491
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# =============================================================================
# External APIs
# =============================================================================
# Perplexity API key for web search functionality (optional)
PERPLEXITY_API_KEY=

# =============================================================================
# Storage
# =============================================================================
UPLOADS_DIR=./uploads

# =============================================================================
# Authentication
# =============================================================================
API_KEY_PREFIX=bvr_
TOKEN_EXPIRE_DAYS=365

# =============================================================================
# RAG Parameters
# =============================================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# =============================================================================
# Limits
# =============================================================================
MAX_UPLOAD_MB=100
MAX_CONTEXT_TOKENS=8192
