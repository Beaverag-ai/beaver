# Generated by beaver install

# Server
API_HOST=0.0.0.0
API_PORT=8741
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://beaver:beaver@localhost:5491/beaver

# Vector Store (pgvector — uses same database)
